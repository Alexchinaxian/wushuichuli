<UserControl x:Class="IndustrialControlHMI.Views.ProcessUnitControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:IndustrialControlHMI.Views"
             xmlns:converters="clr-namespace:IndustrialControlHMI.Converters"
             xmlns:flowchart="clr-namespace:IndustrialControlHMI.Models.Flowchart"
             mc:Ignorable="d"
             d:DesignHeight="100" d:DesignWidth="150"
             Cursor="Hand">
    <UserControl.Resources>
        <!-- 转换器 -->
        <converters:StatusToBrushConverter x:Key="StatusToBrushConverter"/>
        <converters:ColorToBrushConverter x:Key="ColorToBrushConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        
        <!-- 渐变画刷定义 -->
        <LinearGradientBrush x:Key="NormalGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#E3F2FD" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="HoverGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F0F9FF" Offset="0"/>
            <GradientStop Color="#BBDEFB" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="ActiveGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E3F2FD" Offset="0"/>
            <GradientStop Color="#90CAF9" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="AlarmGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FFEBEE" Offset="0"/>
            <GradientStop Color="#FFCDD2" Offset="1"/>
        </LinearGradientBrush>
        
        <!-- 调节池专用状态画刷 -->
        <!-- 运行态：主色 #0077FF，半透明深蓝背景 #1E2A4A -->
        <SolidColorBrush x:Key="RunningBorderBrush" Color="#0077FF"/>
        <SolidColorBrush x:Key="RunningBackgroundBrush" Color="#CC1E2A4A"/> <!-- 80%透明度 -->
        
        <!-- 警告态：橙色 #FF9500，半透明橙色背景 #3A2E1F -->
        <SolidColorBrush x:Key="WarningBorderBrush" Color="#FF9500"/>
        <SolidColorBrush x:Key="WarningBackgroundBrush" Color="#CC3A2E1F"/>
        
        <!-- 报警态：红色 #FF3B30，半透明红色背景 #3A1F1F -->
        <SolidColorBrush x:Key="AlarmRedBorderBrush" Color="#FF3B30"/>
        <SolidColorBrush x:Key="AlarmRedBackgroundBrush" Color="#CC3A1F1F"/>
        
        <!-- 停止/离线态：浅灰 #8E8E93，半透明深灰背景 #2C2C2E -->
        <SolidColorBrush x:Key="OfflineBorderBrush" Color="#8E8E93"/>
        <SolidColorBrush x:Key="OfflineBackgroundBrush" Color="#CC2C2C2E"/>
        
        <!-- 状态颜色 - 调节池专用设计 -->
        <!-- 运行态：主色蓝色 -->
        <SolidColorBrush x:Key="RunningColor" Color="#0077FF"/>
        <!-- 停止/离线态：浅灰色 -->
        <SolidColorBrush x:Key="StoppedColor" Color="#8E8E93"/>
        <!-- 报警态：红色 -->
        <SolidColorBrush x:Key="FaultColor" Color="#FF3B30"/>
        <!-- 警告态：橙色 -->
        <SolidColorBrush x:Key="WarningColor" Color="#FF9500"/>

        <!-- 动画效果 -->
        <!-- 运行态：呼吸动画（柔和） -->
        <Storyboard x:Key="RunningBreathingAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0.85"/>
                <EasingDoubleKeyFrame KeyTime="0:0:2" Value="1.0"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
        
        <!-- 故障/报警态：闪烁动画（快速） -->
        <Storyboard x:Key="FaultBlinkingAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0.5"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="1.0"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
        
        <!-- 警告态：脉冲动画（中等速度，轻微缩放） -->
        <Storyboard x:Key="WarningPulseAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0.75"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1" Value="1.0"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
        
        <Storyboard x:Key="HoverScaleAnimation">
            <DoubleAnimation Storyboard.TargetProperty="ScaleX" To="1.05" Duration="0:0:0.2"/>
            <DoubleAnimation Storyboard.TargetProperty="ScaleY" To="1.05" Duration="0:0:0.2"/>
        </Storyboard>
        
        <Storyboard x:Key="NormalScaleAnimation">
            <DoubleAnimation Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.2"/>
            <DoubleAnimation Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.2"/>
        </Storyboard>

        <!-- 边框样式 -->
        <Style x:Key="UnitBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource NormalGradient}"/>
            <Setter Property="BorderBrush" Value="#90CAF9"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.2" Color="#000000"/>
                </Setter.Value>
            </Setter>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 状态指示灯样式 -->
        <Style x:Key="StatusIndicatorStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Stroke" Value="#FFFFFF"/>
            <Setter Property="StrokeThickness" Value="1"/>
        </Style>
        
        <!-- 自定义工具提示样式 -->
        <Style x:Key="DetailedToolTipStyle" TargetType="ToolTip">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#90CAF9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="MaxWidth" Value="300"/>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding ToolTipDetailed}" 
                                       TextWrapping="Wrap" 
                                       FontSize="12" 
                                       FontFamily="Consolas, Courier New"/>
                        </StackPanel>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 工具提示转换器，将HTML转换为Inline -->
        <converters:HtmlToInlineConverter x:Key="HtmlToInlineConverter"/>
        
        <!-- 右键菜单 -->
        <ContextMenu x:Key="UnitContextMenu" x:Shared="False">
            <MenuItem Header="查看详情" 
                      Command="{Binding DataContext.ViewDetailsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      CommandParameter="{Binding}"/>
            <Separator/>
            <MenuItem Header="模拟故障" 
                      Command="{Binding DataContext.SimulateFaultCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      CommandParameter="{Binding}"/>
            <MenuItem Header="复位故障" 
                      Command="{Binding DataContext.ResetFaultCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      CommandParameter="{Binding}"/>
            <Separator/>
            <MenuItem Header="设备信息">
                <MenuItem Header="{Binding Id}" HeaderStringFormat="设备ID: {0}"/>
                <MenuItem Header="{Binding UnitType}" HeaderStringFormat="类型: {0}"/>
                <MenuItem Header="{Binding StatusText}" HeaderStringFormat="状态: {0}"/>
                <MenuItem Header="{Binding PlcPointCount}" HeaderStringFormat="PLC点位: {0}个"/>
            </MenuItem>
        </ContextMenu>
    </UserControl.Resources>
    
    <Border x:Name="MainBorder"
            Width="{Binding Size.Width}"
            Height="{Binding Size.Height}"
            ToolTip="{Binding ToolTipDetailed}"
            ToolTipService.ShowDuration="60000"
            ContextMenu="{StaticResource UnitContextMenu}">
        
        <Border.Style>
            <Style TargetType="Border" BasedOn="{StaticResource UnitBorderStyle}">
                <Setter Property="Background" Value="{Binding CurrentBackgroundColor, Converter={StaticResource ColorToBrushConverter}}"/>
                <Setter Property="BorderBrush" Value="{Binding CurrentBorderColor, Converter={StaticResource ColorToBrushConverter}}"/>
                <Setter Property="BorderThickness" Value="{Binding CurrentBorderThickness}"/>
                <Setter Property="Opacity" Value="{Binding AnimationOpacity}"/>
                <Setter Property="ToolTip">
                    <Setter.Value>
                        <ToolTip Style="{StaticResource DetailedToolTipStyle}">
                            <ToolTip.Content>
                                <TextBlock Text="{Binding ToolTipDetailed}" TextWrapping="Wrap" FontSize="12"/>
                            </ToolTip.Content>
                        </ToolTip>
                    </Setter.Value>
                </Setter>
                
                <Style.Triggers>
                    <!-- 自来水补水框：禁用所有状态变化，保持静态样式 -->
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding ShowStatusIndicator}" Value="False"/>
                        </MultiDataTrigger.Conditions>
                        <Setter Property="BorderBrush" Value="#2196F3"/>
                        <Setter Property="Background" Value="{StaticResource NormalGradient}"/>
                        <Setter Property="BorderThickness" Value="2"/>
                        <Setter Property="Opacity" Value="1"/>
                        <Setter Property="Effect" Value="{x:Null}"/>
                    </MultiDataTrigger>
                    
                    <!-- 悬停效果 -->
                    <DataTrigger Binding="{Binding IsHovered}" Value="True">
                        <DataTrigger.EnterActions>
                            <BeginStoryboard Storyboard="{StaticResource HoverScaleAnimation}"/>
                        </DataTrigger.EnterActions>
                        <DataTrigger.ExitActions>
                            <BeginStoryboard Storyboard="{StaticResource NormalScaleAnimation}"/>
                        </DataTrigger.ExitActions>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect ShadowDepth="4" BlurRadius="12" Opacity="0.3" Color="#2196F3"/>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                    
                    <!-- 激活状态 -->
                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                        <Setter Property="BorderBrush" Value="{Binding ActiveBorderColor, Converter={StaticResource ColorToBrushConverter}}"/>
                        <Setter Property="BorderThickness" Value="3"/>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect ShadowDepth="4" BlurRadius="12" Opacity="0.4" Color="#1976D2"/>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                    
                    <!-- 故障/报警状态：红色闪烁 -->
                    <DataTrigger Binding="{Binding IsAlarm}" Value="True">
                        <DataTrigger.EnterActions>
                            <BeginStoryboard Storyboard="{StaticResource FaultBlinkingAnimation}"/>
                        </DataTrigger.EnterActions>
                        <Setter Property="BorderBrush" Value="{StaticResource AlarmRedBorderBrush}"/>
                        <Setter Property="Background" Value="{StaticResource AlarmRedBackgroundBrush}"/>
                        <Setter Property="BorderThickness" Value="3"/>
                    </DataTrigger>
                    
                    <!-- 运行状态：主色蓝色呼吸动画 -->
                    <DataTrigger Binding="{Binding Status}" Value="Running">
                        <DataTrigger.EnterActions>
                            <BeginStoryboard Storyboard="{StaticResource RunningBreathingAnimation}"/>
                        </DataTrigger.EnterActions>
                        <Setter Property="BorderBrush" Value="{StaticResource RunningBorderBrush}"/>
                        <Setter Property="Background" Value="{StaticResource RunningBackgroundBrush}"/>
                        <Setter Property="BorderThickness" Value="2.5"/>
                    </DataTrigger>
                    
                    <!-- 警告状态：橙色脉冲动画 -->
                    <DataTrigger Binding="{Binding Status}" Value="Warning">
                        <DataTrigger.EnterActions>
                            <BeginStoryboard Storyboard="{StaticResource WarningPulseAnimation}"/>
                        </DataTrigger.EnterActions>
                        <Setter Property="BorderBrush" Value="{StaticResource WarningBorderBrush}"/>
                        <Setter Property="Background" Value="{StaticResource WarningBackgroundBrush}"/>
                        <Setter Property="BorderThickness" Value="2.5"/>
                    </DataTrigger>
                    
                    <!-- 故障状态：红色闪烁 -->
                    <DataTrigger Binding="{Binding Status}" Value="Fault">
                        <DataTrigger.EnterActions>
                            <BeginStoryboard Storyboard="{StaticResource FaultBlinkingAnimation}"/>
                        </DataTrigger.EnterActions>
                        <Setter Property="BorderBrush" Value="{StaticResource AlarmRedBorderBrush}"/>
                        <Setter Property="Background" Value="{StaticResource AlarmRedBackgroundBrush}"/>
                        <Setter Property="BorderThickness" Value="3"/>
                    </DataTrigger>
                    
                    <!-- 停止/离线状态：灰色低视觉权重 -->
                    <DataTrigger Binding="{Binding Status}" Value="Stopped">
                        <Setter Property="Opacity" Value="0.7"/>
                        <Setter Property="BorderBrush" Value="{StaticResource OfflineBorderBrush}"/>
                        <Setter Property="Background" Value="{StaticResource OfflineBackgroundBrush}"/>
                        <Setter Property="BorderThickness" Value="2"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
            <!-- 状态指示灯 - 根据ShowStatusIndicator属性显示 -->
            <Ellipse x:Name="StatusIndicator"
                     Width="10"
                     Height="10"
                     Margin="0,0,0,4"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Center"
                     Stroke="#FFFFFF"
                     StrokeThickness="1"
                     Fill="{Binding Status, Converter={StaticResource StatusToBrushConverter}}">
                <Ellipse.Style>
                    <Style TargetType="Ellipse">
                        <Style.Triggers>
                            <!-- 自来水补水框隐藏状态指示灯 -->
                            <DataTrigger Binding="{Binding ShowStatusIndicator}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Ellipse.Style>
            </Ellipse>
            <!-- 设备名称 - 根据状态调整颜色 -->
            <TextBlock Text="{Binding Title}"
                       FontSize="14"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       Margin="0,4,0,0"
                       TextWrapping="Wrap">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#FFFFFF"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Status}" Value="Stopped">
                                <Setter Property="Foreground" Value="#AAAAAA"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- 关键参数显示 - 调节池专用浅色文字 -->
            <TextBlock Text="{Binding KeyParametersText}"
                       FontSize="10"
                       Foreground="#CCCCCC"
                       TextAlignment="Center"
                       Margin="0,4,0,0"
                       TextWrapping="Wrap"
                       MaxWidth="130"
                       Visibility="{Binding KeyParametersText, Converter={StaticResource StringToVisibilityConverter}}"/>
            <!-- 状态文本 - 调节池专用状态颜色，自来水补水框不显示 -->
            <TextBlock Text="{Binding StatusText}"
                       FontSize="10"
                       FontWeight="SemiBold"
                       TextAlignment="Center"
                       Margin="0,2,0,0"
                       Foreground="White">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <!-- 自来水补水框隐藏状态文本 -->
                            <DataTrigger Binding="{Binding ShowStatusIndicator}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="Running">
                                <Setter Property="Foreground" Value="#0077FF"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="Warning">
                                <Setter Property="Foreground" Value="#FF9500"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="Fault">
                                <Setter Property="Foreground" Value="#FF3B30"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="Stopped">
                                <Setter Property="Foreground" Value="#8E8E93"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsAlarm}" Value="True">
                                <Setter Property="Foreground" Value="#FF3B30"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>
    </Border>
</UserControl>