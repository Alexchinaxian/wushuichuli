<UserControl x:Class="IndustrialControlHMI.Views.AlarmManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IndustrialControlHMI.Views"
             xmlns:vm="clr-namespace:IndustrialControlHMI.ViewModels"
             xmlns:converters="clr-namespace:IndustrialControlHMI.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题和工具栏 -->
        <Border Grid.Row="0" Background="#0F2342" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="24" Foreground="#00A8FF" Margin="0,0,10,0"/>
                    <TextBlock Text="报警管理" FontSize="18" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding LoadAlarmsCommand}" Style="{StaticResource IconButtonStyle}" ToolTip="刷新">
                        <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="White"/>
                    </Button>
                    <Button Command="{Binding ExportAlarmsCommand}" Style="{StaticResource IconButtonStyle}" ToolTip="导出">
                        <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="White"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 筛选工具栏 -->
        <Border Grid.Row="1" Background="#152A4F" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="状态筛选:" Foreground="#8E8E93" VerticalAlignment="Center" Margin="5"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding StatusFilterOptions}" SelectedItem="{Binding FilterStatus}" Margin="5">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="White"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Grid.Column="2" Text="参数:" Foreground="#8E8E93" VerticalAlignment="Center" Margin="5"/>
                    <TextBox Grid.Column="3" Text="{Binding FilterParameter, UpdateSourceTrigger=PropertyChanged}" Margin="5" Background="#001122" Foreground="White" BorderBrush="#0F2342"/>
                    <TextBlock Grid.Column="4" Text="开始:" Foreground="#8E8E93" VerticalAlignment="Center" Margin="5"/>
                    <DatePicker Grid.Column="5" SelectedDate="{Binding FilterStartDate}" Margin="5" Background="#001122" Foreground="White" BorderBrush="#0F2342"/>
                    <TextBlock Grid.Column="6" Text="结束:" Foreground="#8E8E93" VerticalAlignment="Center" Margin="5"/>
                    <DatePicker Grid.Column="7" SelectedDate="{Binding FilterEndDate}" Margin="5" Background="#001122" Foreground="White" BorderBrush="#0F2342"/>
                    <StackPanel Grid.Column="8" Orientation="Horizontal">
                        <Button Command="{Binding ApplyFilterCommand}" Content="应用筛选" Style="{StaticResource PrimaryButtonStyle}" Margin="5"/>
                        <Button Command="{Binding ClearFilterCommand}" Content="清除" Style="{StaticResource SecondaryButtonStyle}" Margin="5"/>
                    </StackPanel>
                </Grid>

                <!-- 报警记录列表 -->
                <DataGrid Grid.Row="1" ItemsSource="{Binding AlarmRecords}" SelectedItem="{Binding SelectedAlarmRecord}" AutoGenerateColumns="False" CanUserAddRows="False" Margin="0,10,0,0"
                          Background="#001122" BorderBrush="#0F2342" Foreground="White" RowBackground="#152A4F" AlternatingRowBackground="#0A1A2F">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                        <DataGridTextColumn Header="参数名称" Binding="{Binding ParameterName}" Width="120"/>
                        <DataGridTextColumn Header="报警类型" Binding="{Binding AlarmType}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{Binding AlarmType, Converter={StaticResource AlarmTypeToColorConverter}}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="阈值" Binding="{Binding Threshold, StringFormat=F2}" Width="70"/>
                        <DataGridTextColumn Header="实际值" Binding="{Binding ActualValue, StringFormat=F2}" Width="70"/>
                        <DataGridTextColumn Header="消息" Binding="{Binding Message}" Width="200"/>
                        <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{Binding Status, Converter={StaticResource StatusToColorConverter}}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="发生时间" Binding="{Binding OccurrenceTime, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="140"/>
                        <DataGridTextColumn Header="确认时间" Binding="{Binding AcknowledgedTime, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="140"/>
                        <DataGridTextColumn Header="清除时间" Binding="{Binding ClearedTime, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="140"/>
                        <DataGridTemplateColumn Header="操作" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Command="{Binding DataContext.AcknowledgeAlarmCommand, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" 
                                                CommandParameter="{Binding Id}" 
                                                Content="确认" Style="{StaticResource SmallButtonStyle}" Margin="2" Visibility="{Binding Status, Converter={StaticResource StatusToAcknowledgeVisibilityConverter}}"/>
                                        <Button Command="{Binding DataContext.ResolveAlarmCommand, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" 
                                                CommandParameter="{Binding Id}" 
                                                Content="解决" Style="{StaticResource SmallButtonStyle}" Margin="2" Visibility="{Binding Status, Converter={StaticResource StatusToResolveVisibilityConverter}}"/>
                                        <Button Command="{Binding DataContext.DeleteAlarmCommand, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" 
                                                CommandParameter="{Binding Id}" 
                                                Content="删除" Style="{StaticResource DangerButtonStyle}" Margin="2"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- 底部统计信息 -->
        <Border Grid.Row="2" Background="#0F2342" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="总计:" Foreground="#8E8E93" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding TotalAlarms}" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="激活:" Foreground="#FF3B30" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding ActiveAlarms}" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="已确认:" Foreground="#FF9500" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding AcknowledgedAlarms}" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="已解决:" Foreground="#4CD964" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding ResolvedAlarms}" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="最后更新:" Foreground="#8E8E93" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding LastUpdateTime, StringFormat=HH:mm:ss}" Foreground="White"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>