<UserControl x:Class="IndustrialControlHMI.Views.HistoryDataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:views="clr-namespace:IndustrialControlHMI.Views"
             mc:Ignorable="d"
             xmlns:vm="clr-namespace:IndustrialControlHMI.ViewModels"
             d:DesignHeight="650" d:DesignWidth="1100">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="#0F2342" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="24" Foreground="#00A8FF" Margin="0,0,10,0"/>
                    <TextBlock Text="历史数据导出" FontSize="18" FontWeight="Bold" Foreground="White"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding QueryPreviewCommand}" Style="{StaticResource IconButtonStyle}" ToolTip="刷新预览" Margin="5,0,0,0">
                        <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="White"/>
                    </Button>
                    <Button Command="{Binding ExportDataCommand}" Style="{StaticResource IconButtonStyle}" ToolTip="导出" Margin="5,0,0,0">
                        <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="White"/>
                    </Button>
                    <Button Command="{Binding CancelExportCommand}" Style="{StaticResource IconButtonStyle}" ToolTip="取消导出" Margin="5,0,0,0"
                            IsEnabled="{Binding IsExporting}">
                        <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="White"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 筛选与导出设置 -->
        <Border Grid.Row="1" Background="#152A4F" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 上方：数据类型 + 时间窗 -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="数据类型:" Foreground="#8E8E93" VerticalAlignment="Center" Margin="5"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding DataTypeOptions}"
                              SelectedItem="{Binding SelectedDataType, Mode=TwoWay}"
                              Style="{StaticResource DarkComboBoxStyle}"
                              Background="#001122"
                              Foreground="White"
                              BorderBrush="#0F2342"
                              Margin="5">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Background" Value="#001122"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Padding" Value="6,2"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1A00A8FF"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#00A8FF"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>

                    <TextBlock Grid.Column="2" Text="开始:" Foreground="#8E8E93" VerticalAlignment="Center" Margin="5"/>
                    <DatePicker Grid.Column="3"
                                 SelectedDate="{Binding FilterStartDate, Mode=TwoWay}"
                                 Style="{StaticResource DarkDatePickerStyle}"
                                 Margin="5"/>

                    <TextBlock Grid.Column="4" Text="结束:" Foreground="#8E8E93" VerticalAlignment="Center" Margin="5"/>
                    <DatePicker Grid.Column="5"
                                 SelectedDate="{Binding FilterEndDate, Mode=TwoWay}"
                                 Style="{StaticResource DarkDatePickerStyle}"
                                 Margin="5"/>
                </Grid>

                <!-- 中间：处理单元 + 参数 -->
                <Grid Grid.Row="1" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="处理单元(多选):" Foreground="#8E8E93" FontSize="12"/>
                                <TextBlock Text="{Binding SelectedProcessUnitCount}" Foreground="White" FontSize="12" Margin="6,0,0,0"/>
                                <TextBlock Text="/" Foreground="#8E8E93" FontSize="12"/>
                                <TextBlock Text="{Binding TotalProcessUnitCount}" Foreground="#8E8E93" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Command="{Binding SelectAllProcessUnitsCommand}" Content="全选" Style="{StaticResource SmallButtonStyle}" Margin="2,0" Padding="6,2"/>
                                <Button Command="{Binding InvertProcessUnitsCommand}" Content="反选" Style="{StaticResource SmallButtonStyle}" Margin="2,0" Padding="6,2"/>
                                <Button Command="{Binding ClearProcessUnitsCommand}" Content="清空" Style="{StaticResource SmallButtonStyle}" Margin="2,0" Padding="6,2"/>
                            </StackPanel>
                        </Grid>
                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding ProcessUnitOptions}"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 Background="#001122"
                                 BorderBrush="#0F2342"
                                 BorderThickness="1"
                                 Margin="5"
                                 Padding="5">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Foreground="White"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="导出参数(多选):" Foreground="#8E8E93" FontSize="12"/>
                                <TextBlock Text="{Binding SelectedParameterCount}" Foreground="White" FontSize="12" Margin="6,0,0,0"/>
                                <TextBlock Text="/" Foreground="#8E8E93" FontSize="12"/>
                                <TextBlock Text="{Binding TotalParameterCount}" Foreground="#8E8E93" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Command="{Binding SelectAllParametersCommand}" Content="全选" Style="{StaticResource SmallButtonStyle}" Margin="2,0" Padding="6,2"/>
                                <Button Command="{Binding InvertParametersCommand}" Content="反选" Style="{StaticResource SmallButtonStyle}" Margin="2,0" Padding="6,2"/>
                                <Button Command="{Binding ClearParametersCommand}" Content="清空" Style="{StaticResource SmallButtonStyle}" Margin="2,0" Padding="6,2"/>
                            </StackPanel>
                        </Grid>
                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding ParameterOptions}"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 Background="#001122"
                                 BorderBrush="#0F2342"
                                 BorderThickness="1"
                                 Margin="5"
                                 Padding="5">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Foreground="White"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Grid.Row="2"
                                   Margin="5,8,5,0"
                                   Foreground="#8E8E93"
                                   FontSize="12"
                                   Text="提示：未勾选任何处理单元或导出参数时，将无法预览/导出。可点击“全选”。"/>
                    </Grid>
                </Grid>

                <!-- 下方：导出格式 + 高级选项 -->
                <Grid Grid.Row="2" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="格式:" Foreground="#8E8E93" VerticalAlignment="Center" Margin="5"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding ExportFormatOptions}"
                              SelectedItem="{Binding SelectedExportFormat, Mode=TwoWay}"
                              Style="{StaticResource DarkComboBoxStyle}"
                              Margin="5">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource HistoryExportFormatToDisplayConverter}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <CheckBox Content="包含表头" IsChecked="{Binding IncludeHeader, Mode=TwoWay}" Foreground="White" Margin="5"/>
                        <CheckBox Content="压缩为ZIP" IsChecked="{Binding CompressToZip, Mode=TwoWay}" Foreground="White" Margin="5"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- 数据预览 -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <DataGrid ItemsSource="{Binding PreviewRows}"
                      AutoGenerateColumns="False"
                      Style="{StaticResource DataGridStyle}"
                      Margin="0"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="时间(本地)" Binding="{Binding TimestampLocal, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="170"/>
                    <DataGridTextColumn Header="处理单元" Binding="{Binding ProcessUnitTitle}" Width="140"/>
                    <DataGridTextColumn Header="参数名称" Binding="{Binding ParameterName}" Width="220"/>
                    <DataGridTextColumn Header="值" Binding="{Binding Value, StringFormat=F2}" Width="110"/>
                    <DataGridTextColumn Header="质量" Binding="{Binding QualityText}" Width="90"/>
                    <DataGridTextColumn Header="来源(模拟?)" Binding="{Binding IsSimulated}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- 底部进度 -->
        <Border Grid.Row="3" Background="#0F2342" Padding="10" Margin="0,10,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="状态:" Foreground="#8E8E93" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,5,0,0">
                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding ExportProgress}" Height="14"/>
                    <TextBlock Text="{Binding ExportNoDataMessage}" Foreground="#FFD37A" Margin="0,5,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

