<UserControl x:Class="IndustrialControlHMI.Views.FlowchartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:views="clr-namespace:IndustrialControlHMI.Views"
             xmlns:converters="clr-namespace:IndustrialControlHMI.Converters"
             xmlns:viewModels="clr-namespace:IndustrialControlHMI.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=viewModels:FlowchartViewModel, IsDesignTimeCreatable=True}">
    
    <UserControl.Resources>
        <converters:ColorToBrushConverter x:Key="ColorToBrushConverter"/>
        <converters:StatusToBrushConverter x:Key="StatusToBrushConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:IntToVisibilityConverter x:Key="IntToVisibilityConverter"/>
        <converters:BooleanToBrushConverter x:Key="BooleanToBrushConverter"/>
        <converters:BooleanToContentConverter x:Key="BooleanToContentConverter"/>
        
        <!-- 报警计数样式 -->
        <Style x:Key="AlarmCountStyle" TargetType="Border">
            <Setter Property="Background" Value="#FF4444"/>
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        
        <!-- 高亮动画 -->
        <Storyboard x:Key="HighlightAnimation" AutoReverse="True">
            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)">
                <LinearColorKeyFrame KeyTime="0:0:0.5" Value="#4CD964"/>
                <LinearColorKeyFrame KeyTime="0:0:1.0" Value="#00A8FF"/>
            </ColorAnimationUsingKeyFrames>
        </Storyboard>
    </UserControl.Resources>
    
    <!-- 主网格 -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 流程图容器 -->
        <Border Grid.Row="1" Background="#152A4F" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Canvas绘图区域 -->
                <Border Grid.Column="0"
                        Background="#152A4F" 
                        BorderThickness="1" 
                        BorderBrush="#1A3A6A"
                        CornerRadius="5">
                    <!-- 固定画布，不使用缩放 -->
                    <Grid Background="Transparent">
                        <!-- 用 Grid 作为画布容器 -->
                        <Grid Width="1600" Height="850" Background="Transparent" VerticalAlignment="Top">
                            <!-- 连接线（底层） -->
                            <ItemsControl x:Name="FlowLinesControl"
                                          ItemsSource="{Binding FlowLines}"
                                          Grid.Row="0" Grid.Column="0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas IsItemsHost="True"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <views:FlowLineControl FlowLineModel="{Binding}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="0"/>
                                        <Setter Property="Canvas.Top" Value="0"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                            </ItemsControl>
                            <!-- 处理单元（顶层） -->
                            <ItemsControl x:Name="ProcessUnitsControl"
                                          ItemsSource="{Binding ProcessUnits}"
                                          Grid.Row="0" Grid.Column="0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas IsItemsHost="True"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <views:ProcessUnitControl
                                            UnitModel="{Binding}"
                                            ClickCommand="{Binding DataContext.UnitClickCommand,
                                                RelativeSource={RelativeSource AncestorType={x:Type views:FlowchartView}}}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding Position.X}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Position.Y}"/>
                                        <Setter Property="Canvas.ZIndex" Value="{Binding ZIndex}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                            </ItemsControl>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>
        
        <!-- 状态栏 -->
        <Border Grid.Row="2" 
                Background="#001122" 
                BorderThickness="0,1,0,0" 
                BorderBrush="#1A3A6A"
                Height="35">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- 左侧信息 -->
                <StackPanel Grid.Column="0" 
                            Orientation="Horizontal" 
                            Margin="10,0"
                            VerticalAlignment="Center">
                    <!-- 数据更新时间 -->
                    <TextBlock Text="数据更新: " 
                               FontSize="10" 
                               Foreground="#CCCCCC"/>
                    <TextBlock Text="{Binding LastDataUpdateTime, StringFormat='HH:mm:ss'}" 
                               FontSize="10" 
                               Foreground="#4CD964"
                               Margin="5,0,20,0"/>
                    
                    <!-- 选中单元 -->
                    <TextBlock Text="选中单元: " 
                               FontSize="10" 
                               Foreground="#CCCCCC"/>
                    <TextBlock Text="{Binding SelectedUnit.Title, FallbackValue='无'}" 
                               FontSize="10" 
                               Foreground="#4CD964"
                               Margin="5,0,20,0"/>
                    
                    <!-- 报警信息 -->
                    <Border Background="#FF4444" CornerRadius="3" Padding="4,2"
                            Visibility="{Binding AlarmCount, Converter={StaticResource IntToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="报警: " 
                                       FontSize="10" 
                                       Foreground="White"/>
                            <TextBlock Text="{Binding AlarmCount}" 
                                       FontSize="10" 
                                       FontWeight="Bold" 
                                       Foreground="White"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
                
                <!-- 右侧控制按钮 -->
                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal" 
                            Margin="10,0"
                            VerticalAlignment="Center">
                    <!-- PLC连接按钮 -->
                    <Button x:Name="ConnectPlcButton"
                            Content="{Binding IsPlcConnected, Converter={StaticResource BooleanToContentConverter}}"
                            Command="{Binding ConnectPlcCommand}"
                            Padding="10,3"
                            FontSize="10"
                            Margin="0,0,10,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPlcConnected}" Value="True">
                                        <Setter Property="Background" Value="#27ae60"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsPlcConnected}" Value="False">
                                        <Setter Property="Background" Value="#e74c3c"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    
                    <!-- 自动演示切换 -->
                    <ToggleButton x:Name="AutoDemoToggle"
                                  Content="自动演示" 
                                  IsChecked="{Binding IsAutoDemoEnabled}"
                                  Command="{Binding ToggleAutoDemoCommand}"
                                  Padding="10,3"
                                  FontSize="10"
                                  Margin="0,0,10,0"/>
                    
                    <!-- PLC数据绑定切换 -->
                    <ToggleButton x:Name="PlcBindingToggle"
                                  Content="PLC绑定" 
                                  IsChecked="{Binding IsPlcBindingEnabled}"
                                  Command="{Binding TogglePlcBindingCommand}"
                                  Padding="10,3"
                                  FontSize="10"
                                  Margin="0,0,10,0"/>
                    
                    <!-- 刷新数据按钮 -->
                    <Button Content="刷新数据" 
                            Padding="10,3"
                            FontSize="10"
                            Command="{Binding RefreshPlcDataCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>