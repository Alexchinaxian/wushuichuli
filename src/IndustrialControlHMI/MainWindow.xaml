<Window x:Class="IndustrialControlHMI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:IndustrialControlHMI.Converters"
        xmlns:views="clr-namespace:IndustrialControlHMI.Views"
        mc:Ignorable="d"
        Title="工业控制上位机"
        WindowState="Maximized"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <!-- 窗口阴影 -->
    <Window.Effect>
        <DropShadowEffect ShadowDepth="0" BlurRadius="20" Opacity="0.3"/>
    </Window.Effect>

    <!-- 资源定义 -->
    <Window.Resources>
        <!-- 卡片阴影效果 -->
        <DropShadowEffect x:Key="CardShadow" ShadowDepth="0" BlurRadius="4" Opacity="0.1" Color="#000000"/>
        <!-- 字体定义 -->
        <Style x:Key="DeviceNameText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI, Roboto, Microsoft YaHei, sans-serif"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1F2937"/>
        </Style>
        <Style x:Key="ParameterText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI, Roboto, Microsoft YaHei, sans-serif"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#4B5563"/>
        </Style>
        <Style x:Key="UpdateTimeText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI, Roboto, Microsoft YaHei, sans-serif"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
        </Style>
        <Style x:Key="KeyParameterText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI, Roboto, Microsoft YaHei, sans-serif"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1F2937"/>
        </Style>
    </Window.Resources>

    <!-- 主网格布局 -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="646*"/>
            <ColumnDefinition Width="891*"/>
        </Grid.ColumnDefinitions>
        <!-- 背景渐变 -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#0A1A2F" Offset="0"/>
                <GradientStop Color="#152A4F" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <!-- 标题栏 -->
            <RowDefinition Height="*"/>
            <!-- 主要内容 -->
            <RowDefinition Height="30"/>
            <!-- 状态栏 -->
        </Grid.RowDefinitions>

        <!-- ==================== 标题栏 ==================== -->
        <Border Grid.Row="0" Background="#001122" Grid.ColumnSpan="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧: 应用程序标题 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="20,0">
                    <TextBlock Text="" FontFamily="Segoe MDL2 Assets" 
                               FontSize="24" Foreground="#00A8FF" 
                               VerticalAlignment="Center"/>
                    <TextBlock Text="工业控制上位机" FontSize="18" 
                               FontWeight="SemiBold" Foreground="White" 
                               VerticalAlignment="Center" Margin="15,0,0,0"/>
                    <TextBlock Text="v1.0.0" FontSize="12" 
                               Foreground="#CCCCCC" VerticalAlignment="Center" 
                               Margin="10,5,0,0"/>
                </StackPanel>

                <!-- 右侧: 连接状态 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" 
                           HorizontalAlignment="Right" Margin="0,0,20,0">
                    <TextBlock Text="PLC连接:" Foreground="White" 
                               VerticalAlignment="Center" FontSize="12"/>
                    <Ellipse Width="12" Height="12" Margin="5,0,10,0" 
                             VerticalAlignment="Center">
                        <Ellipse.Fill>
                            <SolidColorBrush Color="{Binding ConnectionStatusColor}"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Text="{Binding PlcIpAddress}" Foreground="#CCCCCC" 
                               VerticalAlignment="Center" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== 主要内容区域 ==================== -->
        <Grid Grid.Row="1" Margin="0,1,0,0" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <!-- 导航栏 -->
                <ColumnDefinition Width="*"/>
                <!-- 主内容 -->
                <ColumnDefinition Width="300"/>
                <!-- 右侧面板 -->
            </Grid.ColumnDefinitions>

            <!-- 左侧导航栏 -->
            <Border Grid.Column="0" Background="#0F2342" BorderThickness="0,0,1,0" 
                   BorderBrush="#1A3A6A">
                <StackPanel Margin="0,20,0,0">
                    <!-- 导航按钮样式 -->
                    <StackPanel.Resources>
                        <Style x:Key="NavigationButtonStyle" TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Height" Value="50"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                               CornerRadius="0">
                                            <ContentPresenter HorizontalAlignment="Left" 
                                                            VerticalAlignment="Center" 
                                                            Margin="20,0"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" 
                                                       Value="#1A3A6A"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border" Property="Background" 
                                                       Value="#00A8FF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </StackPanel.Resources>

                    <!-- 导航按钮 -->
                    <Button Style="{StaticResource NavigationButtonStyle}" 
                           Command="{Binding NavigateToDashboardCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" 
                                       FontSize="18" Foreground="White"/>
                            <TextBlock Text="仪表板" FontSize="12" Foreground="White" 
                                       Margin="15,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource NavigationButtonStyle}" 
                           Command="{Binding NavigateToAlarmsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" 
                                       FontSize="18" Foreground="White"/>
                            <TextBlock Text="报警管理" FontSize="12" Foreground="White" 
                                       Margin="15,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource NavigationButtonStyle}" 
                           Command="{Binding NavigateToHistoryCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" 
                                       FontSize="18" Foreground="White"/>
                            <TextBlock Text="历史数据" FontSize="12" Foreground="White" 
                                       Margin="15,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource NavigationButtonStyle}" 
                           Command="{Binding NavigateToSettingsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" 
                                       FontSize="18" Foreground="White"/>
                            <TextBlock Text="参数设置" FontSize="12" Foreground="White" 
                                       Margin="15,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- 中间主内容：仪表板=流程图；参数设置/报警等=CurrentViewModel 对应视图 -->
            <Grid Grid.Column="1" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 仪表板：工艺流程图（CurrentViewModel 为空时显示） -->
                <Border Grid.Row="0" Background="#152A4F" CornerRadius="5"
                       BorderThickness="1" BorderBrush="#1A3A6A"
                       Effect="{StaticResource CardShadow}"
                       Visibility="{Binding CurrentViewModel, Converter={StaticResource ObjectToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#00A8FF"
                               CornerRadius="5,5,0,0" Padding="10,5">
                            <TextBlock Text="MBR污水处理工艺流程可视化"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center">
                                <TextBlock.ToolTip>
                                    <ToolTip>
                                        <StackPanel>
                                            <TextBlock Text="点击处理单元查看详情" FontSize="12"/>
                                            <TextBlock Text="绿色: 运行, 黄色: 停止, 红色: 故障" FontSize="10" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </ToolTip>
                                </TextBlock.ToolTip>
                            </TextBlock>
                        </Border>

                        <Border Grid.Row="1" Margin="0" Background="Transparent">
                            <views:FlowchartView DataContext="{Binding FlowchartViewModel}"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- 参数设置（含 PLC/Modbus 连接）、报警管理等 -->
                <ContentControl Grid.Row="0"
                                Content="{Binding CurrentViewModel}"
                                Visibility="{Binding CurrentViewModel, Converter={StaticResource ObjectToVisibilityConverter}, ConverterParameter=Inverse}"/>
            </Grid>

            <!-- 右侧面板 -->
            <Grid Grid.Column="2" Margin="10,10,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- 状态指示灯 -->
                    <RowDefinition Height="10"/>
                    <!-- 间隔 -->
                    <RowDefinition Height="Auto"/>
                    <!-- 关键参数 -->
                </Grid.RowDefinitions>

                <!-- 状态指示灯区域 -->
                <Border Grid.Row="0" Background="#152A4F" CornerRadius="5" 
                       BorderThickness="1" BorderBrush="#1A3A6A">
                    <StackPanel Margin="10">
                        <!-- 标题 -->
                        <TextBlock Text="设备状态指示" FontSize="14" 
                                   FontWeight="SemiBold" Foreground="White" 
                                   Margin="0,0,0,10"/>

                        <!-- 指示灯区域 -->
                        <WrapPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,15,10">
                                <Ellipse Width="16" Height="16" Fill="#4CD964" 
                                        Stroke="#2C3E50" StrokeThickness="1"/>
                                <TextBlock Text="正常" Foreground="#CCCCCC" 
                                           Margin="5,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,15,10">
                                <Ellipse Width="16" Height="16" Fill="#FF9500" 
                                        Stroke="#2C3E50" StrokeThickness="1"/>
                                <TextBlock Text="警告" Foreground="#CCCCCC" 
                                           Margin="5,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,15,10">
                                <Ellipse Width="16" Height="16" Fill="#FF3B30" 
                                        Stroke="#2C3E50" StrokeThickness="1"/>
                                <TextBlock Text="报警" Foreground="#CCCCCC" 
                                           Margin="5,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,15,10">
                                <Ellipse Width="16" Height="16" Fill="#8E8E93" 
                                        Stroke="#2C3E50" StrokeThickness="1"/>
                                <TextBlock Text="离线" Foreground="#CCCCCC" 
                                           Margin="5,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </WrapPanel>

                        <!-- 当前状态显示 -->
                        <Border Margin="0,10,0,0" Padding="10,5" 
                               Background="{Binding DeviceStatusBrush}" 
                               CornerRadius="3">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="12" Height="12" Fill="White" 
                                        Margin="0,0,5,0"/>
                                <TextBlock Text="{Binding DeviceStatusText}" 
                                           Foreground="White" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 关键参数区域 -->
                <Border Grid.Row="2" Background="#152A4F" CornerRadius="5" 
                       BorderThickness="1" BorderBrush="#1A3A6A">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 标题 -->
                        <TextBlock Grid.Row="0" Text="关键参数监控" FontSize="14" 
                                   FontWeight="SemiBold" Foreground="White" 
                                   Margin="0,0,0,10"/>

                        <!-- 参数卡片 -->
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding KeyParameters}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1A3A6A" CornerRadius="5" 
                                           Margin="0,0,0,10" Padding="10">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Text="{Binding Name}" 
                                                       Foreground="#CCCCCC" FontSize="12"/>

                                            <StackPanel Grid.Row="1" Orientation="Horizontal" 
                                                       HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding Value}" FontSize="24" 
                                                           FontWeight="Bold" Foreground="White"/>
                                                <TextBlock Text="{Binding Unit}" FontSize="16" 
                                                           VerticalAlignment="Bottom" 
                                                           Margin="5,0,0,5" 
                                                           Foreground="#CCCCCC"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ==================== 状态栏 ==================== -->
        <Border Grid.Row="2" Background="#001122" BorderThickness="0,1,0,0" 
               BorderBrush="#1A3A6A" Grid.ColumnSpan="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧状态信息 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="10,0">
                    <TextBlock Text="数据更新:" Foreground="#CCCCCC" 
                               VerticalAlignment="Center" FontSize="10"/>
                    <TextBlock Text="{Binding LastUpdateTime}" Foreground="White" 
                               VerticalAlignment="Center" FontSize="10" 
                               Margin="5,0,20,0"/>

                    <TextBlock Text="报警状态:" Foreground="#CCCCCC" 
                               VerticalAlignment="Center" FontSize="10"/>
                    <TextBlock Text="{Binding AlarmStatusText}" 
                               Foreground="{Binding AlarmStatusColor, Converter={StaticResource ColorToBrushConverter}}" 
                               VerticalAlignment="Center" FontSize="10" 
                               Margin="5,0,0,0" FontWeight="SemiBold"/>
                </StackPanel>

                <!-- 右侧时间显示 -->
                <TextBlock Grid.Column="1" Text="{Binding CurrentDateTime}" 
                           Foreground="#CCCCCC" VerticalAlignment="Center" 
                           FontSize="10" Margin="0,0,10,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
