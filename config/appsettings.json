{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Modbus": {
    "IpAddress": "192.168.1.100",
    "Port": 502,
    "SlaveId": 1,
    "Timeout": 5000,
    "RetryCount": 3,
    "PollingInterval": 1000
  },
  "Database": {
    "ConnectionString": "Data Source=industrial_control.db"
  },
  "Application": {
    "Name": "IndustrialControlHMI",
    "Version": "1.0.0",
    "AutoConnect": false,
    "AutoSaveInterval": 300000,
    "MaxLogFiles": 10,
    "LogRetentionDays": 30
  },
  "UI": {
    "Theme": "Default",
    "AnimationEnabled": true,
    "TooltipDelay": 500,
    "RefreshRate": 30
  },
  "Alarm": {
    "SoundEnabled": true,
    "PopupEnabled": true,
    "AutoAcknowledge": false,
    "RetentionDays": 90
  },
  "Security": {
    "AuthenticationEnabled": false,
    "AutoLockTimeout": 300000,
    "PasswordExpiryDays": 90
  }
}